{
  "groups": {
    "group:admin": ["tm@"]
  },
  "tagOwners": {
    "tag:server": ["group:admin"],
    "tag:dmz": ["group:admin"]
  },
  "acls": [
    {
      "action": "accept",
      "src": ["group:admin"],
      "dst": ["*:*"]
    },
    {
      "action": "accept",
      "src": ["tag:dmz"],
      "dst": ["tag:server:80,443,8080,8096,32400"]
    },
    {
      "action": "accept",
      "src": ["tag:server"],
      "dst": ["tag:server:*"]
    }
  ],
  "ssh": [
    {
      "action": "accept",
      "src": ["group:admin"],
      "dst": ["autogroup:member", "autogroup:tagged"],
      "users": ["root", "autogroup:nonroot"]
    }
  ]
}
